{
  "templates": [
    {
      "name": "Course Completion Certificate",
      "credential_type": "certificate",
      "sub_type": "academic",
      "template_data": {
        "title_template": "Certificate of Completion - {course_name}",
        "description_template": "This certifies that {student_name} has successfully completed {course_name} with a grade of {grade}",
        "required_fields": ["course_name", "student_name", "grade", "completion_date"],
        "optional_fields": ["instructor_name", "course_duration", "credits"],
        "design": {
          "background_color": "#ffffff",
          "border_color": "#1e40af",
          "logo_position": "top-center",
          "signature_positions": ["bottom-left", "bottom-right"]
        },
        "validation_rules": {
          "minimum_grade": "D",
          "minimum_attendance": 75
        }
      }
    },
    {
      "name": "Degree Certificate",
      "credential_type": "certificate",
      "sub_type": "academic",
      "template_data": {
        "title_template": "{degree_type} in {major}",
        "description_template": "Awarded to {student_name} in recognition of successful completion of all requirements for the degree of {degree_type} in {major}",
        "required_fields": ["student_name", "degree_type", "major", "graduation_date", "gpa"],
        "optional_fields": ["honors", "minor", "thesis_title"],
        "design": {
          "background_color": "#fefce8",
          "border_color": "#854d0e",
          "seal_required": true,
          "official_signatures": 3
        },
        "validation_rules": {
          "minimum_gpa": 2.0,
          "minimum_credits": 120
        }
      }
    },
    {
      "name": "Skill Badge - Programming",
      "credential_type": "digital_badge",
      "sub_type": "skill_based",
      "template_data": {
        "title_template": "{skill_name} Expert Badge",
        "description_template": "Earned by demonstrating proficiency in {skill_name} through practical assessments and projects",
        "required_fields": ["skill_name", "proficiency_level", "assessment_date"],
        "optional_fields": ["projects_completed", "assessment_score", "endorsements"],
        "skills_taxonomy": [
          "Python",
          "JavaScript",
          "Java",
          "C++",
          "SQL",
          "React",
          "Django",
          "FastAPI",
          "Docker",
          "Kubernetes"
        ],
        "proficiency_levels": ["Beginner", "Intermediate", "Advanced", "Expert"],
        "design": {
          "badge_shape": "hexagon",
          "primary_color": "#3b82f6",
          "icon_type": "skill_specific"
        }
      }
    },
    {
      "name": "Skill Badge - Soft Skills",
      "credential_type": "digital_badge",
      "sub_type": "skill_based",
      "template_data": {
        "title_template": "{skill_name} Badge",
        "description_template": "Demonstrated competency in {skill_name} through leadership activities and peer evaluations",
        "required_fields": ["skill_name", "demonstration_date"],
        "optional_fields": ["peer_endorsements", "projects", "activities"],
        "skills_taxonomy": [
          "Leadership",
          "Communication",
          "Teamwork",
          "Problem Solving",
          "Critical Thinking",
          "Time Management",
          "Public Speaking",
          "Project Management"
        ],
        "design": {
          "badge_shape": "circle",
          "primary_color": "#8b5cf6",
          "icon_type": "generic_achievement"
        }
      }
    },
    {
      "name": "Event Participation Badge",
      "credential_type": "digital_badge",
      "sub_type": "participation",
      "template_data": {
        "title_template": "{event_name} Participant",
        "description_template": "Participated in {event_name} on {event_date}",
        "required_fields": ["event_name", "event_date"],
        "optional_fields": ["role", "team_name", "achievements", "hours_participated"],
        "design": {
          "badge_shape": "star",
          "primary_color": "#10b981",
          "event_logo": true
        }
      }
    },
    {
      "name": "Hackathon Winner Certificate",
      "credential_type": "certificate",
      "sub_type": "participation",
      "template_data": {
        "title_template": "{hackathon_name} - {position} Place",
        "description_template": "Awarded for achieving {position} place in {hackathon_name} with project '{project_name}'",
        "required_fields": ["hackathon_name", "position", "project_name", "event_date"],
        "optional_fields": ["team_members", "project_description", "technologies_used", "prize"],
        "design": {
          "background_color": "#f0fdf4",
          "border_color": "#15803d",
          "trophy_icon": true,
          "position_badge": true
        },
        "validation_rules": {
          "valid_positions": ["1st", "2nd", "3rd", "Runner-up"]
        }
      }
    },
    {
      "name": "Internship Completion Certificate",
      "credential_type": "certificate",
      "sub_type": "academic",
      "template_data": {
        "title_template": "Internship Completion Certificate",
        "description_template": "This certifies that {student_name} has successfully completed an internship at {company_name} in the role of {position} from {start_date} to {end_date}",
        "required_fields": ["student_name", "company_name", "position", "start_date", "end_date"],
        "optional_fields": ["supervisor_name", "key_responsibilities", "skills_acquired", "performance_rating"],
        "design": {
          "background_color": "#ffffff",
          "border_color": "#0369a1",
          "company_logo": true,
          "institution_logo": true
        },
        "validation_rules": {
          "minimum_duration_weeks": 8
        }
      }
    },
    {
      "name": "Workshop Attendance Badge",
      "credential_type": "digital_badge",
      "sub_type": "participation",
      "template_data": {
        "title_template": "{workshop_name} Attendee",
        "description_template": "Attended {workshop_name} conducted by {instructor_name}",
        "required_fields": ["workshop_name", "attendance_date", "instructor_name"],
        "optional_fields": ["duration_hours", "topics_covered", "completion_status"],
        "design": {
          "badge_shape": "square",
          "primary_color": "#f59e0b",
          "icon_type": "education"
        }
      }
    },
    {
      "name": "Research Publication Certificate",
      "credential_type": "certificate",
      "sub_type": "academic",
      "template_data": {
        "title_template": "Research Publication Certificate",
        "description_template": "In recognition of the publication of research paper titled '{paper_title}' in {journal_name}",
        "required_fields": ["paper_title", "journal_name", "publication_date", "authors"],
        "optional_fields": ["doi", "citation_count", "impact_factor", "peer_review_status"],
        "design": {
          "background_color": "#fefce8",
          "border_color": "#ca8a04",
          "academic_seal": true
        }
      }
    },
    {
      "name": "Community Service Badge",
      "credential_type": "digital_badge",
      "sub_type": "participation",
      "template_data": {
        "title_template": "Community Service - {service_hours} Hours",
        "description_template": "Completed {service_hours} hours of community service through {organization_name}",
        "required_fields": ["service_hours", "organization_name", "service_dates"],
        "optional_fields": ["activities", "impact_statement", "supervisor_contact"],
        "design": {
          "badge_shape": "heart",
          "primary_color": "#ef4444",
          "icon_type": "community"
        },
        "validation_rules": {
          "minimum_hours": 10
        }
      }
    }
  ]
}
