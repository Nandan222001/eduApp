# AWS Configuration
aws_region   = "us-east-1"
project_name = "fastapi-app"
environment  = "prod"

# VPC Configuration
vpc_cidr             = "10.0.0.0/16"
public_subnet_cidrs  = ["10.0.1.0/24", "10.0.2.0/24"]
private_subnet_cidrs = ["10.0.11.0/24", "10.0.12.0/24"]

# RDS Configuration
db_name                     = "fastapi_db"
db_username                 = "postgres"
db_password                 = "CHANGE_ME_IN_PRODUCTION"
db_instance_class           = "db.t3.small"
db_allocated_storage        = 20
db_engine_version           = "16.1"
db_backup_retention_period  = 7
db_backup_window            = "03:00-04:00"
db_maintenance_window       = "mon:04:00-mon:05:00"
db_multi_az                 = true

# Redis Configuration
redis_node_type          = "cache.t3.micro"
redis_num_cache_nodes    = 1
redis_engine_version     = "7.0"
redis_snapshot_retention = 5
redis_snapshot_window    = "03:00-05:00"
redis_maintenance_window = "sun:05:00-sun:07:00"

# ECS Configuration
container_cpu     = 512
container_memory  = 1024
desired_count     = 2
app_port          = 8000
health_check_path = "/health"

# Auto Scaling Configuration
min_capacity        = 2
max_capacity        = 10
target_cpu_value    = 70
target_memory_value = 80

# SSL Certificate
certificate_arn = "arn:aws:acm:us-east-1:123456789012:certificate/xxxxx"
domain_name     = "api.example.com"

# Application Secrets (use AWS Secrets Manager or environment variables in production)
secret_key            = "CHANGE_ME_IN_PRODUCTION"
aws_access_key_id     = "YOUR_AWS_ACCESS_KEY"
aws_secret_access_key = "YOUR_AWS_SECRET_KEY"
sendgrid_api_key      = "YOUR_SENDGRID_API_KEY"
sentry_dsn            = "YOUR_SENTRY_DSN"

# SNS Topic for Alerts
sns_topic_arn = "arn:aws:sns:us-east-1:123456789012:alerts"
