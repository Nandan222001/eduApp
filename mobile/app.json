{
  "expo": {
    "name": "EDU Mobile",
    "slug": "edu-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "edumobile",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.edu.mobile",
      "buildNumber": "1",
      "associatedDomains": [
        "applinks:edu.app"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.edu.mobile",
      "versionCode": 1,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "edu.app",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "sentry-expo",
        {
          "organization": "your-sentry-org",
          "project": "edu-mobile"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow EDU Mobile to access your camera to take photos for assignment submissions and document scanning."
        }
      ],
      [
        "expo-barcode-scanner",
        {
          "cameraPermission": "Allow EDU Mobile to access your camera to scan QR codes for quick access features."
        }
      ],
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow EDU Mobile to access your photos to upload profile pictures and assignment files.",
          "cameraPermission": "Allow EDU Mobile to access your camera to take profile pictures and assignment photos."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow EDU Mobile to save images to your photo library.",
          "savePhotosPermission": "Allow EDU Mobile to save images to your photo library.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow EDU Mobile to use Face ID for secure authentication."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#2089dc",
          "sounds": [],
          "mode": "production"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "your-project-id"
      }
    },
    "notification": {
      "icon": "./assets/notification-icon.png",
      "color": "#2089dc",
      "androidMode": "default",
      "androidCollapsedTitle": "EDU Mobile"
    }
  }
}
