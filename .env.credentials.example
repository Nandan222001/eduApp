# Blockchain Digital Credential System Configuration

# Application URL (used for verification links and QR codes)
APP_URL=http://localhost:8000

# Blockchain Network Configuration
BLOCKCHAIN_ENABLED=true
BLOCKCHAIN_NETWORK_PATH=./blockchain/network
BLOCKCHAIN_CHANNEL=credentialchannel
BLOCKCHAIN_CHAINCODE=credentials
BLOCKCHAIN_PEER_ADDRESS=peer0.education.credentials.com:7051
BLOCKCHAIN_ORDERER_ADDRESS=orderer.credentials.com:7050

# Credential Configuration
CREDENTIAL_CERTIFICATE_PREFIX=CERT
CREDENTIAL_QR_CODE_SIZE=10
CREDENTIAL_QR_CODE_BORDER=5

# Share Link Configuration
CREDENTIAL_SHARE_DEFAULT_EXPIRY_DAYS=30
CREDENTIAL_SHARE_MAX_VIEWS=0  # 0 = unlimited

# Verification Configuration
CREDENTIAL_VERIFICATION_LOG_ENABLED=true
CREDENTIAL_PUBLIC_VERIFICATION_ENABLED=true

# Email Notifications (Optional)
CREDENTIAL_EMAIL_NOTIFICATION_ENABLED=false
CREDENTIAL_EMAIL_ON_ISSUANCE=false
CREDENTIAL_EMAIL_ON_REVOCATION=false
CREDENTIAL_EMAIL_ON_SHARE=false

# Template Configuration
CREDENTIAL_TEMPLATE_ENABLED=true
CREDENTIAL_DEFAULT_EXPIRY_YEARS=5

# Blockchain Fallback
BLOCKCHAIN_USE_MOCK_ON_FAILURE=true
BLOCKCHAIN_RETRY_ATTEMPTS=3
BLOCKCHAIN_TIMEOUT_SECONDS=30

# Security
CREDENTIAL_VERIFICATION_RATE_LIMIT=100  # per hour per IP
CREDENTIAL_SHARE_RATE_LIMIT=10  # per hour per user

# Storage
CREDENTIAL_QR_CODE_STORAGE=base64  # base64 or s3
CREDENTIAL_QR_CODE_S3_BUCKET=credentials-qr-codes  # if using S3

# Analytics
CREDENTIAL_ANALYTICS_ENABLED=true
CREDENTIAL_TRACK_VERIFICATIONS=true
CREDENTIAL_TRACK_SHARES=true

# Export/Import
CREDENTIAL_EXPORT_ENABLED=true
CREDENTIAL_EXPORT_FORMATS=pdf,json,csv
CREDENTIAL_BULK_IMPORT_MAX_SIZE=1000

# Cache Configuration
CREDENTIAL_CACHE_ENABLED=true
CREDENTIAL_CACHE_TTL_SECONDS=3600
CREDENTIAL_VERIFICATION_CACHE_TTL_SECONDS=300

# Blockchain Network Monitoring
BLOCKCHAIN_HEALTH_CHECK_ENABLED=true
BLOCKCHAIN_HEALTH_CHECK_INTERVAL_SECONDS=60
BLOCKCHAIN_ALERT_ON_FAILURE=true

# Logging
CREDENTIAL_LOG_LEVEL=INFO
CREDENTIAL_LOG_BLOCKCHAIN_OPERATIONS=true
CREDENTIAL_LOG_VERIFICATIONS=true

# Development Mode
DEV_MODE=false
DEV_USE_MOCK_BLOCKCHAIN=false
DEV_SKIP_BLOCKCHAIN_VERIFICATION=false
