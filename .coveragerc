[run]
source = src
omit =
    */tests/*
    */test_*.py
    */migrations/*
    */alembic/*
    */__init__.py
    */config.py
    */conftest.py
branch = True
parallel = True

[report]
precision = 2
exclude_lines =
    pragma: no cover
    def __repr__
    def __str__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    class .*\bProtocol\):
    @(abc\.)?abstractmethod
    @overload
    except ImportError:
skip_empty = True
fail_under = 70

[html]
directory = htmlcov

[xml]
output = coverage.xml

[paths]
source =
    src
    */site-packages
