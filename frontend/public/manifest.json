        {
          "src": "/icons/shortcut-dashboard.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Attendance",
      "short_name": "Attendance",
      "description": "Mark attendance",
      "url": "/attendance",
      "icons": [
        {
          "src": "/icons/shortcut-attendance.png",
