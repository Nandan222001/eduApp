# PostgreSQL to MySQL Migration Configuration
# Copy this file to migration_config.env and fill in your database credentials
# Usage: source migration_config.env && python scripts/migrate_postgres_to_mysql.py --postgres-url $POSTGRES_URL --mysql-url $MYSQL_URL

# PostgreSQL Source Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DATABASE=source_db

# MySQL Target Database
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=mysql
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=target_db

# Migration Options
MIGRATION_BATCH_SIZE=1000
MIGRATION_EXCLUDE_TABLES=alembic_version

# Constructed URLs (do not edit these)
POSTGRES_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DATABASE}
MYSQL_URL=mysql+pymysql://${MYSQL_USER}:${MYSQL_PASSWORD}@${MYSQL_HOST}:${MYSQL_PORT}/${MYSQL_DATABASE}
