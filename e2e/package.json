{
  "name": "e2e-tests",
  "version": "1.0.0",
  "description": "End-to-end test suite for the educational platform",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:chromium": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "test:mobile": "playwright test --project='Mobile Chrome' --project='Mobile Safari'",
    "test:student": "playwright test tests/student",
    "test:teacher": "playwright test tests/teacher",
    "test:parent": "playwright test tests/parent",
    "test:admin": "playwright test tests/admin",
    "test:visual": "playwright test tests/visual",
    "test:a11y": "playwright test tests/accessibility",
    "test:performance": "playwright test tests/performance",
    "test:integration": "playwright test tests/integration",
    "test:smoke": "playwright test --grep @smoke",
    "test:ci": "playwright test --workers=1",
    "update-snapshots": "playwright test --update-snapshots",
    "show-report": "playwright show-report",
    "show-trace": "playwright show-trace",
    "codegen": "playwright codegen http://localhost:5173"
  },
  "keywords": [
    "e2e",
    "playwright",
    "testing",
    "automation"
  ],
  "author": "Education Platform Team",
  "license": "MIT"
}
