# E2E Test Environment Variables

# Base URL for the application
BASE_URL=http://localhost:5173

# Test user credentials
TEST_STUDENT_EMAIL=student@test.com
TEST_STUDENT_PASSWORD=TestPass123!

TEST_TEACHER_EMAIL=teacher@test.com
TEST_TEACHER_PASSWORD=TestPass123!

TEST_PARENT_EMAIL=parent@test.com
TEST_PARENT_PASSWORD=TestPass123!

